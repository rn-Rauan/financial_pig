# Dependencies
node_modules/

# Build output
dist/
build/
.vite/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage and test output intentionally ignored if tools are run locally
coverage/
test-results/
playwright-report/

# TypeScript and framework caches
*.tsbuildinfo
.eslintcache

# Defensive: TS should never emit config JS/d.ts to the repo root (noEmit is set
# in tsconfig.app.json/tsconfig.node.json). Ignore them in case of misconfig.
/vite.config.js
/vite.config.d.ts

# Deployment caches
.vercel/
.netlify/

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Generated prototype runtime; the prototype is kept as static HTML reference
docs/prototypes/support.js
